{
  "extends": ["@commitlint/config-conventional"],
  "rules": {
    "scope-enum": [
      2, "always", [
        "web", "api", "ai", "infra",
        "l1", "l2", "l3", "l4", "l5",
        "l6", "l7", "l8", "l9", "l10",
        "l11", "l12", "deps", "ci", "docs"
      ]
    ],
    "subject-max-length": [2, "always", 100]
  }
}
