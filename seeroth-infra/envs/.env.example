# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://seeroth:password@localhost:5432/seeroth_db
DATABASE_POOL_SIZE=10

# ── Cache ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── AI ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_TEMPERATURE=0.3

# ── Market Data ───────────────────────────────────────────
POLYGON_API_KEY=your_polygon_key
FMP_API_KEY=your_fmp_key
ALPHA_VANTAGE_API_KEY=your_av_key
BENZINGA_API_KEY=your_benzinga_key

# ── Halal Screening ───────────────────────────────────────
ZOYA_API_KEY=your_zoya_key

# ── Macro Data ────────────────────────────────────────────
FRED_API_KEY=your_fred_key

# ── Auth ──────────────────────────────────────────────────
JWT_SECRET=change_me_to_minimum_256_bit_secret_in_production
JWT_EXPIRY_MS=86400000
JWT_REFRESH_EXPIRY_MS=604800000

# ── Storage ───────────────────────────────────────────────
CLOUDFLARE_R2_ACCOUNT_ID=your_r2_account
CLOUDFLARE_R2_ACCESS_KEY=your_r2_key
CLOUDFLARE_R2_SECRET_KEY=your_r2_secret
CLOUDFLARE_R2_BUCKET=seeroth-assets

# ── App ───────────────────────────────────────────────────
APP_ENV=development
APP_PORT_API=8080
APP_PORT_AI=8000
CORS_ALLOWED_ORIGINS=http://localhost:4200
